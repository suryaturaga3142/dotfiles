#!/usr/bin/env bash

# Outdated, used to have performance, balanced, power-saver
#MODE="$(powerprofilesctl get)"
MODE=$(auto-cpufreq --get-state)

ICON=""
COLOR=""
FMT=""

case "$MODE" in
    performance)
        ICON="󰓅"
        COLOR="green"
        FMT="Performance"
        ;;
    default)
        ICON="󰾅"
        COLOR="orange"
        FMT="Balanced"
        ;;
    powersave)
        ICON="󰾆"
        COLOR="red"
        FMT="Power Saver"
        ;;
esac

echo "{ \"text\": \"<span color='${COLOR}'>${ICON}</span>\", \"tooltip\": \"${FMT}\" }"

