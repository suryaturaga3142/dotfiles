#!/usr/bin/env bash

capacity=$(cat /sys/class/power_supply/BAT0/capacity)
status=$(cat /sys/class/power_supply/BAT0/status)

if [ "$capacity" -ge 95 ]; then icon="σΑ¹Ι"
elif [ "$capacity" -ge 90 ]; then icon="σΑ²²"
elif [ "$capacity" -ge 80 ]; then icon="σΑ²¹"
elif [ "$capacity" -ge 70 ]; then icon="σΑ²Ä"
elif [ "$capacity" -ge 60 ]; then icon="σΑ¹Ω"
elif [ "$capacity" -ge 50 ]; then icon="σΑ¹Ψ"
elif [ "$capacity" -ge 40 ]; then icon="σΑ¹Ϋ"
elif [ "$capacity" -ge 30 ]; then icon="σΑ¹Φ"
elif [ "$capacity" -ge 20 ]; then icon="σΑ¹Μ"
elif [ "$capacity" -ge 10 ]; then icon="σΑ¹Κ"
else icon="σΑ²é"
fi

indicator=""
if [ "$status" = "Charging" ]; then
    # Soft green lightning bolt
    indicator="<span foreground='#a6e3a1'>σ±ê΄</span>" 
elif [ "$capacity" -le 20 ]; then
    # Warning red exclamation
    indicator="<span foreground='#ff5b78'>σ±àΗ</span>"
fi

echo "<span>${icon} ${capacity}% ${indicator}</span>"
