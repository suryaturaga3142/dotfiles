# ~/.config/mako/config

anchor=top-right
layer=overlay
default-timeout=1000
ignore-timeout=0
max-visible=5
sort=-time

width=350
height=150
margin=12
padding=12
border-radius=12
border-size=2

[urgency=critical]
anchor=center
default-timeout=5000
border-color=#dd0f0f

[app-name=vol_bright_adj]
anchor=top-center
default-timeout=500
width=250
height=30
padding=1
border-size=1
border-radius=6
font="JetBrainsMono Nerd Font 16"

[app-name=Hyprshot]
on-button-left=exec qimgv "$HOME/Pictures/Screenshots/$(ls -t $HOME/Pictures/Screenshots/ | head -n 1)" & makoctl dismiss -n "$id"
on-button-right=dismiss

[app-name=screenshot_delay]
width=50
height=50
text-alignment=center

