#!/bin/bash
# ~/.bash_functions

if [ -f ~/.bash_aliases ]; then
    . ~/.bash_aliases
fi

# Make Directory and Change into it
mkcd() {
    mkdir -p "$1"
    cd "$1" || return 1
}

# Universal Extractor
extract() {
    if [ -f "$1" ] ; then
        echo -e "Extracting ${YELLOW}$1${NC}..."
        case "$1" in
            *.tar.bz2)   tar xjf "$1"    ;;
            *.tar.gz)    tar xzf "$1"    ;;
            *.bz2)       bunzip2 "$1"    ;;
            *.rar)       unrar e "$1"    ;;
            *.gz)        gunzip "$1"     ;;
            *.tar)       tar xf "$1"     ;;
            *.tbz2)      tar xjf "$1"    ;;
            *.tgz)       tar xzf "$1"    ;;
            *.zip)       unzip "$1"      ;;
            *.Z)         uncompress "$1" ;;
            *.7z)        7z x "$1"       ;;
            *)           
                echo -e "${RED}Error:${NC} '${YELLOW}$1${NC}' cannot be extracted via extract()" 
                return 1
                ;;
        esac
        if [ $? -eq 0 ]; then
            echo -e "${GREEN}Success!${NC}"
        fi
    else
        echo -e "${RED}Error:${NC} '${YELLOW}$1${NC}' is not a valid file"
        return 1
    fi
}

