# Conda manager
cm () {
    # Check if conda is installed and available in PATH
    if ! command -v conda >/dev/null 2>&1; then
        echo -e "${RED}Error:${NC} conda command not found. Please install Miniconda first."
        return 1
    fi

    # Fetch available conda environments
    local get_conda_list=($(conda env list | awk '/^[a-zA-Z0-9_-]/ {print $1}'))

    show_usage() {
        echo -e "${B_PURPLE}Conda Env Manager${NC}"
        echo -e "Usage: cm ${YELLOW}<name>${NC} [flags]"
        echo ""
        echo -e "Commands:"
        echo -e "  ${YELLOW}<name>${NC}         Activate an existing conda env (e.g., 'cm work')."
        echo -e "  ${YELLOW}<name>${NC} ${CYAN}--create${NC} Create and activate a new conda env."
        echo -e "  ${CYAN}list${NC}           List all available conda envs."
        echo -e "  ${CYAN}--kill${NC}         Deactivate the current session."
        echo -e "  ${CYAN}--help${NC}         Show this help message."
        echo ""
        
        if [ ${#get_conda_list[@]} -eq 0 ]; then
            echo -e "Detected Envs: ${RED}None${NC}"
        else
            echo -e "Detected Envs: ${YELLOW}${get_conda_list[*]}${NC}"
        fi
    }

    if [[ -z "$1" || "$1" == "--help" || "$1" == "-h" ]]; then
        show_usage
        unset -f show_usage
        return 0
    fi

    local MODE="$1"
    local FLAG="$2"

    case "$MODE" in
        list)
            echo -e "${B_PURPLE}Available Conda Environments:${NC}"
            if [ ${#get_conda_list[@]} -eq 0 ]; then
                echo "  (None)"
            else
                for c in "${get_conda_list[@]}"; do
                    # Add a little star if it's the currently active env
                    if [[ "$CONDA_DEFAULT_ENV" == "$c" ]]; then
                        echo -e "  - ${GREEN}$c${NC} (active)"
                    else
                        echo "  - $c"
                    fi
                done
            fi
            ;;

        --kill)
            # CONDA_DEFAULT_ENV is a built-in variable conda uses to track the active env
            if [[ -n "$CONDA_DEFAULT_ENV" && "$CONDA_DEFAULT_ENV" != "base" ]]; then
                conda deactivate
                echo -e "${GREEN}Success:${NC} Conda environment deactivated."
            elif [[ "$CONDA_DEFAULT_ENV" == "base" ]]; then
                conda deactivate
                echo -e "${YELLOW}Warning:${NC} Deactivated base environment."
            else
                echo -e "${RED}Error:${NC} No conda environment is currently active."
                return 1
            fi
            ;;

        *)
            local ENV_NAME="$MODE"
            local env_exists=false

            # Check if requested env is in fetched list
            for e in "${get_conda_list[@]}"; do
                if [[ "$e" == "$ENV_NAME" ]]; then
                    env_exists=true
                    break
                fi
            done
            
            if [ "$FLAG" == "--create" ]; then
                if [ "$env_exists" = true ]; then
                    echo -e "${YELLOW}Warning:${NC} '$ENV_NAME' already exists. Activating..."
                else
                    echo -e "Creating new conda env: ${CYAN}$ENV_NAME${NC}..."
                    # Automatically installs default python to mimic standard venv behavior
                    conda create -y -n "$ENV_NAME" python
                    
                    if [ $? -eq 0 ]; then
                        echo -e "${GREEN}Success:${NC} Conda env created."
                    else
                        echo -e "${RED}Error:${NC} Conda creation failed."
                        return 1
                    fi
                fi
            elif [ "$env_exists" = false ]; then
                echo -e "${RED}Error:${NC} Conda env '${YELLOW}$ENV_NAME${NC}' does not exist."
                echo -e "To create it, run: ${CYAN}cm $MODE --create${NC}"
                return 1
            fi

            echo -e "Activating ${CYAN}$ENV_NAME${NC}..."
            # Conda shell functions must be initialized in bashrc for this to work natively
            conda activate "$ENV_NAME"
            ;;
    esac

    unset -f show_usage
}

# Manage python venvs
vm () {

    local VENV_ROOT_DIR="$HOME/stuff/venvs"

    get_venv_list=()
    if [ -d "$VENV_ROOT_DIR" ]; then
        for dir in "$VENV_ROOT_DIR"/venv-*/; do
            [ -d "$dir" ] || continue
            local base=$(basename "$dir")
            get_venv_list+=("${base#venv-}")
        done
    fi

    show_usage() {
        echo -e "${B_PURPLE}Python Venv Manager${NC}"
        echo -e "Usage: vm ${YELLOW}<name>${NC} [flags]"
        echo ""
        echo -e "Commands:"
        echo -e "  ${YELLOW}<name>${NC}          Activate an existing venv (e.g., 'vm work')."
        echo -e "  ${YELLOW}<name>${NC} ${CYAN}--create${NC} Create and activate a new venv."
        echo -e "  ${CYAN}list${NC}            List all available venvs."
        echo -e "  ${CYAN}--kill${NC}          Deactivate the current session."
        echo -e "  ${CYAN}--help${NC}          Show this help message."
        echo ""
        
        if [ ${#get_venv_list[@]} -eq 0 ]; then
            echo -e "Detected Venvs: ${RED}None${NC}"
        else
            echo -e "Detected Venvs: ${YELLOW}${get_venv_list[*]}${NC}"
        fi
    }

    if [[ -z "$1" || "$1" == "--help" || "$1" == "-h" ]]; then
        show_usage
        return 0
    fi

    local MODE="$1"
    local FLAG="$2"

    if [ ! -d "$VENV_ROOT_DIR" ]; then
        echo -e "${CYAN}Initializing Venv Root at ${YELLOW}$VENV_ROOT_DIR${NC}..."
        mkdir -p "$VENV_ROOT_DIR"
    fi

    case "$MODE" in
        list)
            echo -e "${B_PURPLE}Available Virtual Environments:${NC}"
            if [ ${#get_venv_list[@]} -eq 0 ]; then
                echo "  (None)"
            else
                for v in "${get_venv_list[@]}"; do
                    echo "  - $v"
                done
            fi
            ;;

        --kill)
            if type deactivate >/dev/null 2>&1; then
                deactivate
                echo -e "${GREEN}Success:${NC} Environment deactivated."
            else
                echo -e "${RED}Error:${NC} No virtual environment is currently active."
                return 1
            fi
            ;;

        *)
            local ENV_NAME="venv-$MODE"
            local TARGET_DIR="$VENV_ROOT_DIR/$ENV_NAME"
            
            if [ "$FLAG" == "--create" ]; then
                if [ -d "$TARGET_DIR" ]; then
                    echo -e "${YELLOW}Warning:${NC} '$ENV_NAME' already exists. Activating..."
                else
                    echo -e "Creating new venv: ${CYAN}$ENV_NAME${NC}..."
                    python -m venv "$TARGET_DIR"
                    
                    if [ $? -eq 0 ]; then
                        echo -e "${GREEN}Success:${NC} Venv created."
                    else
                        echo -e "${RED}Error:${NC} Python creation failed."
                        return 1
                    fi
                fi
            elif [ ! -d "$TARGET_DIR" ]; then
                echo -e "${RED}Error:${NC} Venv '${YELLOW}$ENV_NAME${NC}' does not exist."
                echo -e "To create it, run: ${CYAN}vm $MODE --create${NC}"
                return 1
            fi

            local ACTIVATE_SCRIPT="$TARGET_DIR/bin/activate"
            if [ -f "$ACTIVATE_SCRIPT" ]; then
                echo -e "Activating ${CYAN}$ENV_NAME${NC}..."
                source "$ACTIVATE_SCRIPT"
            else
                echo -e "${RED}Error:${NC} Venv folder exists, but cannot find activation script."
                return 1
            fi
            ;;
    esac

    unset -f get_venv_list
    unset -f show_usage
}

